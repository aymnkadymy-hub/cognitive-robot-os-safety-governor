<!-- 3D arena + car (body + 4 wheels) as kinematic mocap bodies + mocap obstacles. Driven by a bicycle kinematic model. -->
<mujoco model="car_arena">
  <option timestep="0.02"/>
  <visual><global offwidth="640" offheight="480"/></visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.5 0.6 0.78" rgb2="0.1 0.15 0.28" width="256" height="256"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.5 0.58 0.5" rgb2="0.72 0.78 0.72" width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="22 14" reflectance="0.08"/>
  </asset>

  <worldbody>
    <light pos="0 0 7" dir="0 0 -1" diffuse="0.95 0.95 0.95"/>
    <geom name="floor" type="plane" size="6 4 0.1" material="grid"/>

    <geom name="wN" type="box" size="5.7 0.1 0.3" pos="0  3.7 0.3" rgba="0.4 0.4 0.46 1"/>
    <geom name="wS" type="box" size="5.7 0.1 0.3" pos="0 -3.7 0.3" rgba="0.4 0.4 0.46 1"/>
    <geom name="wE" type="box" size="0.1 3.8 0.3" pos="5.7 0 0.3" rgba="0.4 0.4 0.46 1"/>
    <geom name="wW" type="box" size="0.1 3.8 0.3" pos="-5.7 0 0.3" rgba="0.4 0.4 0.46 1"/>

    <!-- obstacles (randomized each episode) -->
    <body name="o0" mocap="true" pos="2 1 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o1" mocap="true" pos="-2 -1 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o2" mocap="true" pos="3 -2 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o3" mocap="true" pos="-3 2 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o4" mocap="true" pos="0 2.5 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o5" mocap="true" pos="0 -2.5 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o6" mocap="true" pos="4 1.5 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>
    <body name="o7" mocap="true" pos="-4 -1.5 0.25"><geom type="box" size="0.3 0.3 0.25" rgba="0.85 0.25 0.2 1"/></body>

    <!-- target (green) for RL driving -->
    <body name="target" mocap="true" pos="3 2 0.2"><geom type="cylinder" size="0.3 0.2" rgba="0.2 0.8 0.3 1"/></body>

    <!-- car: body + 4 wheels (mocap, placed by the kinematic model) -->
    <body name="car" mocap="true" pos="-4.5 -3 0.16">
      <geom type="box" size="0.26 0.15 0.08" rgba="0.15 0.5 0.88 1"/>
      <geom type="box" size="0.13 0.13 0.06" pos="-0.04 0 0.12" rgba="0.1 0.4 0.72 1"/>
    </body>
    <body name="w_rl" mocap="true" pos="0 0 0.09"><geom type="box" size="0.09 0.04 0.09" rgba="0.08 0.08 0.08 1"/></body>
    <body name="w_rr" mocap="true" pos="0 0 0.09"><geom type="box" size="0.09 0.04 0.09" rgba="0.08 0.08 0.08 1"/></body>
    <body name="w_fl" mocap="true" pos="0 0 0.09"><geom type="box" size="0.09 0.04 0.09" rgba="0.05 0.05 0.05 1"/></body>
    <body name="w_fr" mocap="true" pos="0 0 0.09"><geom type="box" size="0.09 0.04 0.09" rgba="0.05 0.05 0.05 1"/></body>
  </worldbody>
</mujoco>
